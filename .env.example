# ==========================================
# Breakpoint V2 — Environment Configuration
# ==========================================

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/breakpoint?retryWrites=true&w=majority

# JWT Secret (generate with: openssl rand -base64 64)
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRY=7d

# LLM Providers
# Default provider: "gemini" or "openai"
DEFAULT_LLM_PROVIDER=gemini

# Gemini API Key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI API Key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your-openai-api-key-here

# Vercel Blob Storage (auto-configured on Vercel)
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token-here

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
